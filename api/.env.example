# Server
PORT=3001
NODE_ENV=development
API_BASE_URL=https://your-domain.com

# MongoDB
MONGODB_URI=mongodb://localhost:27017/loyalr

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Twilio Verify
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apple Wallet
APPLE_PASS_TYPE_ID=pass.com.yourcompany.loyalr
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_WWDR_CERT=-----BEGIN CERTIFICATE-----...
APPLE_SIGNER_CERT=-----BEGIN CERTIFICATE-----...
APPLE_SIGNER_KEY=-----BEGIN RSA PRIVATE KEY-----...
APPLE_KEY_PASSPHRASE=your_key_passphrase
APPLE_AUTH_TOKEN=your_apple_auth_token

# Google Wallet
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_ISSUER_ID=your_google_issuer_id

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
